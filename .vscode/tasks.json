{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "dotnet run",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start AI Service",
      "type": "shell",
      "command": "uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
      "options": { "cwd": "${workspaceFolder}/ai-service" },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start UI",
      "type": "shell",
      "command": "npm start",
      "options": { "cwd": "${workspaceFolder}/ui" },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Start Kitsune (All)",
      "dependsOn": ["Start Backend", "Start AI Service", "Start UI"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}